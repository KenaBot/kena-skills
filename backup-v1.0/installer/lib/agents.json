{
  "version": "1.0.0",
  "description": "Registry of supported agent runtimes for kena-skills installer",
  "agents": [
    {
      "id": "opencode",
      "npx_flag": "opencode",
      "global_dir": ".config/opencode/skills",
      "project_dir": ".opencode/skills",
      "symlink_compatible": true,
      "detect": "test -d $HOME/.config/opencode",
      "description": "OpenCode CLI and TUI"
    },
    {
      "id": "claude-code",
      "npx_flag": "claude-code",
      "global_dir": ".claude/skills",
      "project_dir": ".claude/skills",
      "symlink_compatible": true,
      "detect": "test -d $HOME/.claude",
      "description": "Claude Code CLI"
    },
    {
      "id": "codex",
      "npx_flag": "codex",
      "global_dir": ".codex/skills",
      "project_dir": ".agents/skills",
      "symlink_compatible": true,
      "detect": "test -d $HOME/.codex",
      "description": "OpenAI Codex CLI"
    },
    {
      "id": "agents",
      "npx_flag": "agents",
      "global_dir": ".agents/skills",
      "project_dir": ".agents/skills",
      "symlink_compatible": true,
      "detect": "true",
      "description": "Universal agents-compatible (cline, cursor, zed, etc.)"
    }
  ]
}
